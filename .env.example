# Template de configuration - À adapter avec vos paramètres réels
# Copier ce fichier en .env et remplir avec vos valeurs

# ====== EXCHANGE CONFIGURATION ======
EXCHANGE_NAME=binance
API_KEY=your_api_key_here
API_SECRET=your_api_secret_here
EXCHANGE_SANDBOX=true

# ====== TRADING PARAMETERS ======
BASE_CURRENCY=USDT
TRADE_PAIR=BTC/USDT
POSITION_SIZE=0.01
LEVERAGE=1

# ====== RISK MANAGEMENT ======
STOP_LOSS_PERCENT=2.0
TAKE_PROFIT_PERCENT=5.0
MAX_TRADES=5
MAX_DAILY_LOSS_PERCENT=10.0
TRAILING_STOP_PERCENT=1.0

# ====== AI MODEL ======
MODEL_PATH=./models/price_predictor.pkl
PREDICTION_HORIZON=1h
CONFIDENCE_THRESHOLD=0.65
UPDATE_MODEL_FREQ=24h

# ====== LOGGING ======
LOG_LEVEL=INFO
LOG_FILE=./logs/hamx_smart.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# ====== DATABASE ======
DATABASE_URL=postgresql://user:password@localhost/hamx_smart
DB_ECHO=false

# ====== API DASHBOARD ======
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

# ====== NOTIFICATIONS ======
SLACK_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ====== PERFORMANCE TRACKING ======
ENABLE_METRICS=true
METRICS_PORT=9090